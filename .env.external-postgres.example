# SupaVector self-hosted quickstart with external Postgres
# Use this when you want SupaVector to run its own gateway/vector services
# but connect to a Postgres instance you already manage.
#
# Quick start:
#   cp .env.external-postgres.example .env.external-postgres
#   # edit the PG* values, secrets, and your provider key(s)
#   docker compose -f docker-compose.external-postgres.yml --env-file .env.external-postgres up -d --build
#   docker compose -f docker-compose.external-postgres.yml --env-file .env.external-postgres exec gateway \
#     node scripts/bootstrap_instance.js --username admin --password change_me --tenant default --service-token-name app-bootstrap

# Core
OPENAI_API_KEY=
GEMINI_API_KEY=
# GEMINI_API is also accepted as an alias, but GEMINI_API_KEY is preferred.
ANTHROPIC_API_KEY=
JWT_SECRET=change_me_jwt_secret
COOKIE_SECRET=change_me_cookie_secret
COOKIE_SECURE=0
PUBLIC_BASE_URL=http://localhost:3000
OPENAPI_BASE_URL=http://localhost:3000

# External Postgres connection
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=supavector
PGUSER=supavector
PGPASSWORD=change_me

# Optional local port override
GATEWAY_HOST_PORT=3000

# JWT
JWT_ISSUER=supavector
JWT_AUDIENCE=supavector
JWT_EXPIRES_IN=1h

# Auth protection
AUTH_MAX_ATTEMPTS=5
AUTH_LOCK_MINUTES=15
# Self-hosted browser registration stays off after bootstrap unless you turn it on.
PUBLIC_REGISTRATION_ENABLED=0
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
TENANT_RATE_LIMIT_WINDOW_MS=60000
TENANT_RATE_LIMIT_MAX=120
LOGIN_RATE_LIMIT_WINDOW_MS=60000
LOGIN_RATE_LIMIT_MAX=10

# Startup / migrations
MIGRATIONS_AUTO=1
MIGRATIONS_ATTEMPTS=15
MIGRATIONS_DELAY_MS=2000

# Model / request behavior
OPENAI_TIMEOUT_MS=600000
JSON_BODY_LIMIT=64mb
MAX_DOC_CHARS=2000000
MAX_FETCH_CHARS=5000000
EMBED_FALLBACK_ON_ERROR=1
QUERY_EMBED_CACHE_TTL_MS=30000
QUERY_EMBED_CACHE_MAX_ITEMS=256
# SupaVector provider/model examples:
# ANSWER_PROVIDER / BOOLEAN_ASK_PROVIDER / REFLECT_PROVIDER / COMPACT_PROVIDER can be:
#   openai, gemini, anthropic
# EMBED_PROVIDER can be:
#   openai, gemini
# ANSWER_MODEL examples:
#   openai: gpt-5.2, gpt-5-mini, gpt-5-nano
#   gemini: gemini-2.5-flash, gemini-2.5-pro, gemini-2.5-flash-lite, gemini-2.0-flash
#   anthropic: claude-sonnet-4-20250514, claude-opus-4-20250514, claude-3-7-sonnet-latest, claude-3-5-haiku-latest
# EMBED_MODEL examples:
#   openai: text-embedding-3-large (recommended), text-embedding-3-small
#   gemini: gemini-embedding-001
# Custom provider-native model ids are also allowed.
# GPT-5 presets are supported; SupaVector omits unsupported temperature parameters automatically.
ANSWER_PROVIDER=openai
ANSWER_MODEL=gpt-5.2
BOOLEAN_ASK_PROVIDER=
BOOLEAN_ASK_MODEL=
EMBED_PROVIDER=openai
EMBED_MODEL=text-embedding-3-large
REFLECT_PROVIDER=openai
REFLECT_MODEL=gpt-5-mini
COMPACT_PROVIDER=
COMPACT_MODEL=gpt-5-nano
# Vector-store durability
# Leave this at 0 for the default OSS profile. Set it to 1 only if you want
# vector WAL persistence across restart instead of reindex-only recovery.
VECTOR_WAL=0
VECTOR_SEARCH_MODE=exact
VECTOR_ANN_ENABLED=0
VECTOR_ANN_MIN_CANDIDATES=5000
VECTOR_ANN_OVERFETCH=5
VECTOR_ANN_EXACT_RESCORE=1
VECTOR_ANN_ROLLOUT_PERCENT=100
VECTOR_ANN_SHADOW_SAMPLE_RATE=1
VECTOR_ANN_MIN_SHADOW_OVERLAP=0.8
VECTOR_ANN_LOW_OVERLAP_LIMIT=3
VECTOR_ANN_CIRCUIT_OPEN_MS=300000
VECTOR_ANN_LSH_TABLES=8
VECTOR_ANN_LSH_BITS=12
ALLOW_PRINCIPAL_OVERRIDE=0
FETCH_USER_AGENT=supavector-self-hosted

# Background jobs and memory lifecycle
TTL_SWEEP_INTERVAL_MS=300000
TTL_SWEEP_BATCH_SIZE=200
STORAGE_BILLING_ACCRUAL_INTERVAL_MS=3600000
STORAGE_USAGE_SYNC_DEBOUNCE_MS=5000
DOCS_BULK_MAX_ITEMS=250
JOB_MAX_ATTEMPTS=3
JOB_RETRY_BASE_MS=2000
JOB_RETRY_MAX_MS=30000
JOB_SWEEP_INTERVAL_MS=5000
JOB_SWEEP_BATCH_SIZE=20
MEMORY_EVENT_FLUSH_INTERVAL_MS=250
MEMORY_VALUE_DECAY_INTERVAL_MS=3600000
MEMORY_VALUE_BATCH_SIZE=200
MEMORY_VALUE_MAX_ITEMS=0
MEMORY_REDUNDANCY_INTERVAL_MS=86400000
MEMORY_REDUNDANCY_BATCH_SIZE=100
MEMORY_REDUNDANCY_TOP_K=8
MEMORY_REDUNDANCY_QUERY_CHARS=800
MEMORY_LIFECYCLE_INTERVAL_MS=86400000
MEMORY_LIFECYCLE_BATCH_SIZE=50
MEMORY_LIFECYCLE_MIN_AGE_HOURS=24
MEMORY_LIFECYCLE_MAX_DELETES=0
MEMORY_LIFECYCLE_DRY_RUN=0
MEMORY_LIFECYCLE_DELETE_THRESHOLD=0.25
MEMORY_LIFECYCLE_SUMMARY_THRESHOLD=0.45
MEMORY_LIFECYCLE_PROMOTE_THRESHOLD=0.70
MEMORY_LIFECYCLE_COMPACT_GROUP_SIZE=5
MEMORY_LIFECYCLE_COMPACT_DELETE_ORIGINALS=1
MEMORY_PROMOTION_MAX_ITEMS=3
MEMORY_PROMOTION_COOLDOWN_HOURS=24
MEMORY_COMPACT_COOLDOWN_HOURS=24

# Retrieval defaults
CHUNK_STRATEGY=token
CHUNK_MAX_TOKENS=220
CHUNK_OVERLAP_TOKENS=40
CHUNK_MAX_CHARS=900
CODE_CHUNK_MAX_TOKENS=360
CODE_CHUNK_OVERLAP_TOKENS=72
HYBRID_RETRIEVAL_ENABLED=1
HYBRID_FUSION_MODE=rrf
HYBRID_RRF_K=60
HYBRID_VECTOR_WEIGHT=0.72
HYBRID_LEXICAL_WEIGHT=0.28
HYBRID_LEXICAL_MULTIPLIER=2
HYBRID_LEXICAL_CAP=120
HYBRID_RERANK_OVERLAP_BOOST=0.12
HYBRID_RERANK_EXACT_BOOST=0.08
TENANT_SEARCH_MULTIPLIER=5
TENANT_SEARCH_CAP=50
RETRIEVAL_QUERY_RECENCY_AUTO_ENABLED=1
MEMORY_RETRIEVAL_RECENCY_WEIGHT=0.3
MEMORY_RETRIEVAL_RECENCY_HALFLIFE_DAYS=14

# Telemetry (off by default)
TELEMETRY_ENABLED=0
TELEMETRY_CONFIG_ID=default
TELEMETRY_RUN_ID=
TELEMETRY_FILE=/app/telemetry/events.ndjson
TELEMETRY_SNAPSHOT_INTERVAL_MS=300000

# Optional SSO
OIDC_GOOGLE_CLIENT_ID=
OIDC_GOOGLE_CLIENT_SECRET=
OIDC_GOOGLE_ISSUER=
OIDC_GOOGLE_SCOPES=openid email profile
OIDC_GOOGLE_TENANT_CLAIM=
OIDC_GOOGLE_ROLE_CLAIM=groups
OIDC_GOOGLE_ALLOWED_DOMAINS=
OIDC_GOOGLE_DEFAULT_ROLES=

OIDC_AZURE_CLIENT_ID=
OIDC_AZURE_CLIENT_SECRET=
OIDC_AZURE_ISSUER=
OIDC_AZURE_SCOPES=openid email profile
OIDC_AZURE_TENANT_CLAIM=
OIDC_AZURE_ROLE_CLAIM=groups
OIDC_AZURE_ALLOWED_DOMAINS=
OIDC_AZURE_DEFAULT_ROLES=

OIDC_OKTA_CLIENT_ID=
OIDC_OKTA_CLIENT_SECRET=
OIDC_OKTA_ISSUER=
OIDC_OKTA_SCOPES=openid email profile
OIDC_OKTA_TENANT_CLAIM=
OIDC_OKTA_ROLE_CLAIM=groups
OIDC_OKTA_ALLOWED_DOMAINS=
OIDC_OKTA_DEFAULT_ROLES=
